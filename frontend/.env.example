# ============================================
# RAKSHA ASSIST - FRONTEND ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env: cp .env.example .env
# Works for both LOCAL development and PRODUCTION deployment

# ============================================
# 1. BACKEND API URL - REQUIRED
# ============================================
# LOCAL DEVELOPMENT:
VITE_API_BASE_URL=http://localhost:5000

# PRODUCTION (update with your Render/backend URL):
# VITE_API_BASE_URL=https://your-backend.onrender.com

# ============================================
# 2. APP CONFIGURATION
# ============================================
VITE_APP_NAME=Raksha Assist

# ============================================
# 3. FIREBASE PHONE AUTHENTICATION (Optional)
# ============================================
# Get from: https://console.firebase.google.com
# Project Settings > General > Your apps > Firebase SDK config
# Without these, Demo OTP mode is enabled (OTP: 123456)

# VITE_FIREBASE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxx
# VITE_FIREBASE_PROJECT_ID=your-project-id
# VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# ============================================
# 4. RAZORPAY (Optional)
# ============================================
# Get from: https://dashboard.razorpay.com/app/keys
# Without this, Demo payment mode is enabled

# VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# ============================================
# QUICK START CHECKLIST
# ============================================
# [ ] VITE_API_BASE_URL - http://localhost:5000 for local
# [ ] Run: npm install
# [ ] Run: npm run dev (starts on port 3000)
#
# Demo Mode (no API keys needed):
# - Login: Any 10-digit mobile + OTP "123456"
# - Payments: Demo mode auto-completes
