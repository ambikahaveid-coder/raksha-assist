# ============================================
# RAKSHA ASSIST - BACKEND ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env: cp .env.example .env
# Works for both LOCAL development and PRODUCTION deployment

# ============================================
# 1. SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=development
# For production: NODE_ENV=production

# ============================================
# 2. DATABASE (Supabase PostgreSQL) - REQUIRED
# ============================================
# Get from: Supabase Dashboard > Settings > Database > Connection string
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ============================================
# 3. SESSION & SECURITY - REQUIRED
# ============================================
# Generate a strong random string (32+ characters)
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=generate-a-strong-random-string-at-least-32-chars

# ============================================
# 4. CORS - FRONTEND URL - REQUIRED
# ============================================
# LOCAL DEVELOPMENT:
FRONTEND_URL=http://localhost:3000

# PRODUCTION (update with your actual domain):
# FRONTEND_URL=https://your-frontend.vercel.app
# Multiple domains (comma-separated):
# FRONTEND_URL=https://rakshaassist.com,https://www.rakshaassist.com

# ============================================
# 5. OPENAI API KEY (for Voice Assistant)
# ============================================
# Get from: https://platform.openai.com/api-keys
# Optional - Voice assistant will be disabled without this
OPENAI_API_KEY=sk-your-openai-api-key

# ============================================
# 6. RAZORPAY PAYMENT GATEWAY
# ============================================
# Get from: https://dashboard.razorpay.com/app/keys
# Optional - Demo payment mode works without these
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret-key

# ============================================
# 7. EMAIL SERVICE (Optional)
# ============================================
# Choose ONE email provider:

# Option A: Resend (recommended)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Option B: SendGrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx

# ============================================
# 8. OTP/SMS PROVIDER
# ============================================
# Options: demo, firebase, twilio, msg91
# Default is 'demo' - any 10-digit number + OTP "123456" works
OTP_PROVIDER=demo

# For Twilio SMS (if using twilio):
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# 9. CANONICAL SUPER ADMIN - REQUIRED
# ============================================
# Production only supports one canonical superadmin identity.
SUPERADMIN_EMAIL=superadmin@rakshaassist.com
SUPERADMIN_PASSWORD=replace-with-a-strong-password

# ============================================
# 10. WEB PUSH NOTIFICATIONS (Optional)
# ============================================
# Generate keys: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=your-vapid-public-key
# VAPID_PRIVATE_KEY=your-vapid-private-key

# ============================================
# QUICK START CHECKLIST
# ============================================
# [ ] DATABASE_URL - Your Supabase connection string
# [ ] SESSION_SECRET - Any random 32+ character string
# [ ] FRONTEND_URL - http://localhost:3000 for local
# [ ] Run: npm run db:push (to create database tables)
# [ ] Run: npm run dev (to start server)
